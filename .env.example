# Copy this file to ".env" in the repo root and set DB_URL (never commit ".env").
#
# Neon (recommended: use the "pooled" connection string from the dashboard).
# Keep sslmode=require. If you see TLS / channel-binding errors on Windows, try
# removing "&channel_binding=require" from the query string.
#
# DB_URL=postgresql://USER:PASSWORD@ep-....neon.tech/neondb?sslmode=require

# LLM provider settings.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# Long-term memory settings.
# CHATBOT_MEMORY_MODEL=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CHATBOT_LOG_MEMORY=0
# CHATBOT_MEMORY_DEDUPE_SIMILARITY=0.88
# CHATBOT_PROMPT_MEMORY_LIMIT=8
# CHATBOT_PROMPT_MEMORY_LINE_CHAR_LIMIT=240
# CHATBOT_ACTIVE_MEMORY_LIMIT=100
# CHATBOT_TOTAL_MEMORY_LIMIT=1000

# Application-level rate limiting (Redis/Upstash recommended in production).
# Protects against API abuse and excessive LLM usage, but does not replace
# edge-level DDoS protection such as Cloudflare, Ingress, or API gateway limits.
# RATE_LIMIT_ENABLED=0
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_DEFAULT_PER_MINUTE=60
# RATE_LIMIT_LOGIN_PER_MINUTE=5
# RATE_LIMIT_REGISTER_PER_MINUTE=3
# RATE_LIMIT_CHAT_SEND_PER_MINUTE=10
# RATE_LIMIT_BOT_CREATE_PER_MINUTE=5
# RATE_LIMIT_PROFILE_UPDATE_PER_MINUTE=20
# RATE_LIMIT_EXEMPT_PATHS=/health,/ready,/docs,/openapi.json,/redoc
# RATE_LIMIT_TRUST_PROXY_HEADERS=0
# RATE_LIMIT_LOG_SECRET=
