# Backend API base URL (no trailing slash). Used for production builds / Vercel.
#
# Local FastAPI:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
#
# Hosted (e.g. Render):
# NEXT_PUBLIC_API_URL=https://your-service.onrender.com
#
# `npm run dev` ignores NEXT_PUBLIC_API_URL and uses http://127.0.0.1:8000 unless you set:
# NEXT_PUBLIC_DEV_USE_REMOTE_API=1

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
